{
  "openapi": "3.1.0",
  "info": {
    "title": "Yukine Metadata Gateway",
    "version": "2.0.0",
    "description": "Music metadata aggregation API for Node and Cloudflare Worker runtimes."
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness",
        "responses": {
          "200": {
            "description": "Runtime is alive"
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Readiness",
        "responses": {
          "200": {
            "description": "Configured state backends are ready"
          },
          "503": {
            "description": "A required state backend is unavailable"
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "OpenAPI 3.1 document",
        "responses": {
          "200": {
            "description": "OpenAPI document"
          }
        }
      }
    },
    "/v1/recordings/search": {
      "get": {
        "summary": "Legacy recording search",
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Legacy v1 response"
          },
          "400": {
            "description": "Missing query"
          },
          "502": {
            "description": "Upstream failure"
          }
        }
      }
    },
    "/v1/artists/search": {
      "get": {
        "summary": "Legacy artist search",
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Legacy v1 response"
          },
          "400": {
            "description": "Missing query"
          },
          "502": {
            "description": "Upstream failure"
          }
        }
      }
    },
    "/v1/lyrics/search": {
      "get": {
        "summary": "Legacy lyrics search",
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Legacy v1 response"
          },
          "400": {
            "description": "Missing query"
          },
          "502": {
            "description": "Upstream failure"
          }
        }
      }
    },
    "/v2/recordings/search": {
      "get": {
        "summary": "Canonical recording search",
        "parameters": [
          {
            "in": "query",
            "name": "title",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          },
          {
            "in": "query",
            "name": "artist",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          },
          {
            "in": "query",
            "name": "recordingMbid",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          {
            "in": "query",
            "name": "isrc",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 32,
              "pattern": "^[a-z0-9-]+$"
            }
          },
          {
            "in": "query",
            "name": "fingerprint",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 16384
            }
          },
          {
            "in": "query",
            "name": "fingerprintDuration",
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Canonical recordings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recordings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "canonicalId": {
                            "type": "string",
                            "minLength": 1
                          },
                          "title": {
                            "type": "string"
                          },
                          "artists": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "name": {
                                  "type": "string"
                                },
                                "sortName": {
                                  "type": "string"
                                }
                              },
                              "required": [
                                "id",
                                "name"
                              ],
                              "additionalProperties": false
                            }
                          },
                          "album": {
                            "type": "string"
                          },
                          "coverUrl": {
                            "type": "string"
                          },
                          "durationMs": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 9007199254740991
                          },
                          "identifiers": {
                            "type": "object",
                            "properties": {
                              "recordingMbid": {
                                "type": "string"
                              },
                              "workMbid": {
                                "type": "string"
                              },
                              "isrc": {
                                "type": "string"
                              },
                              "acoustId": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          "fingerprintVerified": {
                            "type": "boolean"
                          },
                          "confidence": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "sources": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "provider": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "id": {
                                  "type": "string"
                                },
                                "role": {
                                  "type": "string",
                                  "enum": [
                                    "identity",
                                    "metadata",
                                    "enrichment"
                                  ]
                                },
                                "matchedBy": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "fields": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "confidence": {
                                  "type": "number",
                                  "minimum": 0,
                                  "maximum": 1
                                }
                              },
                              "required": [
                                "provider",
                                "id",
                                "role",
                                "matchedBy",
                                "fields",
                                "confidence"
                              ],
                              "additionalProperties": false
                            }
                          },
                          "possibleDuplicates": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "canonicalId": {
                                  "type": "string"
                                },
                                "confidence": {
                                  "type": "number",
                                  "minimum": 0,
                                  "maximum": 1
                                }
                              },
                              "required": [
                                "canonicalId",
                                "confidence"
                              ],
                              "additionalProperties": false
                            }
                          }
                        },
                        "required": [
                          "canonicalId",
                          "title",
                          "artists",
                          "album",
                          "coverUrl",
                          "identifiers",
                          "fingerprintVerified",
                          "confidence",
                          "sources",
                          "possibleDuplicates"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "recordings"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "invalid_request"
                    },
                    "requestId": {
                      "type": "string"
                    },
                    "issues": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string"
                          },
                          "code": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "field",
                          "code"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "error",
                    "requestId",
                    "issues"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "502": {
            "description": "All required upstream providers failed"
          }
        }
      }
    },
    "/v2/artists/search": {
      "get": {
        "summary": "Canonical artist search",
        "parameters": [
          {
            "in": "query",
            "name": "name",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          },
          {
            "in": "query",
            "name": "artistMbid",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Canonical artists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "artists": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "canonicalId": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "sortName": {
                            "type": "string"
                          },
                          "aliases": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "country": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "identifiers": {
                            "type": "object",
                            "properties": {
                              "artistMbid": {
                                "type": "string"
                              },
                              "wikidata": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          "avatarUrl": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          },
                          "confidence": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "sources": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "provider": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "id": {
                                  "type": "string"
                                },
                                "role": {
                                  "type": "string",
                                  "enum": [
                                    "identity",
                                    "metadata",
                                    "enrichment"
                                  ]
                                },
                                "matchedBy": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "fields": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "confidence": {
                                  "type": "number",
                                  "minimum": 0,
                                  "maximum": 1
                                }
                              },
                              "required": [
                                "provider",
                                "id",
                                "role",
                                "matchedBy",
                                "fields",
                                "confidence"
                              ],
                              "additionalProperties": false
                            }
                          }
                        },
                        "required": [
                          "canonicalId",
                          "name",
                          "sortName",
                          "aliases",
                          "country",
                          "type",
                          "identifiers",
                          "avatarUrl",
                          "description",
                          "confidence",
                          "sources"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "artists"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "invalid_request"
                    },
                    "requestId": {
                      "type": "string"
                    },
                    "issues": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string"
                          },
                          "code": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "field",
                          "code"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "error",
                    "requestId",
                    "issues"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "502": {
            "description": "All required upstream providers failed"
          }
        }
      }
    },
    "/v2/lyrics/search": {
      "get": {
        "summary": "Canonical lyrics search",
        "parameters": [
          {
            "in": "query",
            "name": "title",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            },
            "required": true
          },
          {
            "in": "query",
            "name": "artist",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          },
          {
            "in": "query",
            "name": "album",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          },
          {
            "in": "query",
            "name": "durationMs",
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Canonical lyrics or null",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lyrics": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "canonicalId": {
                              "type": "string"
                            },
                            "title": {
                              "type": "string"
                            },
                            "artist": {
                              "type": "string"
                            },
                            "album": {
                              "type": "string"
                            },
                            "durationMs": {
                              "type": "integer",
                              "minimum": 0,
                              "maximum": 9007199254740991
                            },
                            "syncedLyrics": {
                              "type": "string"
                            },
                            "plainLyrics": {
                              "type": "string"
                            },
                            "confidence": {
                              "type": "number",
                              "minimum": 0,
                              "maximum": 1
                            },
                            "sources": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "provider": {
                                    "type": "string",
                                    "minLength": 1
                                  },
                                  "id": {
                                    "type": "string"
                                  },
                                  "role": {
                                    "type": "string",
                                    "enum": [
                                      "identity",
                                      "metadata",
                                      "enrichment"
                                    ]
                                  },
                                  "matchedBy": {
                                    "type": "array",
                                    "items": {
                                      "type": "string"
                                    }
                                  },
                                  "fields": {
                                    "type": "array",
                                    "items": {
                                      "type": "string"
                                    }
                                  },
                                  "confidence": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 1
                                  }
                                },
                                "required": [
                                  "provider",
                                  "id",
                                  "role",
                                  "matchedBy",
                                  "fields",
                                  "confidence"
                                ],
                                "additionalProperties": false
                              }
                            }
                          },
                          "required": [
                            "canonicalId",
                            "title",
                            "artist",
                            "album",
                            "durationMs",
                            "syncedLyrics",
                            "plainLyrics",
                            "confidence",
                            "sources"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": [
                    "lyrics"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "invalid_request"
                    },
                    "requestId": {
                      "type": "string"
                    },
                    "issues": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string"
                          },
                          "code": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "field",
                          "code"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "error",
                    "requestId",
                    "issues"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "502": {
            "description": "All required upstream providers failed"
          }
        }
      }
    }
  }
}
