{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": [
    "src/core.ts",
    "src/transport.ts",
    "src/types.ts",
    "src/node/**/*.ts"
  ]
}
